{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/hooks/check-js.mjs"],
            "timeout": 30,
            "statusMessage": "Syntax-checking edited JS"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [".claude/hooks/test-gate.mjs"],
            "timeout": 120,
            "statusMessage": "Delivery gate: running test suite"
          }
        ]
      }
    ]
  }
}
